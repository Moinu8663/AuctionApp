{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "5a1185f2-f168-4159-87df-67d0d735b4ca"
  },
  "newProjectRoot": "projects",
  "projects": {
    "AuctionFrontendApp": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": ["src/material-theme.scss", "src/styles.css"],
            "server": "src/main.server.ts",
            "outputMode": "server",
            "security": {
              "allowedHosts": []
            },
            "ssr": {
              "entry": "src/server.ts"
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "AuctionFrontendApp:build:production"
            },
            "development": {
              "buildTarget": "AuctionFrontendApp:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "tsconfig.spec.json"
          },
          "configurations": {
            "coverage": {
              "coverage": true,
              "coverageReporters": ["text", "lcov", "html", "json-summary"],
              "coverageExclude": [
                "src/main.ts",
                "src/main.server.ts",
                "src/server.ts",
                "src/app/app.config.ts",
                "src/app/app.config.server.ts",
                "src/app/app.routes.ts",
                "src/app/app.routes.server.ts",
                "**/*.spec.ts",
                "**/*.d.ts"
              ],
              "coverageThresholds": {
                "lines": 50,
                "functions": 50,
                "branches": 50,
                "statements": 50
              }
            }
          }
        }
      }
    }
  }
}
